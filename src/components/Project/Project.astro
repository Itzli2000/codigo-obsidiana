---
import { Image } from "astro:assets";
import MainLayout from "../../layouts/MainLayout.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import type { Lang } from "../../types/language";
import { CDN, TYPE } from "../../constants/cdn";
import { NETWORK } from "../../constants/network";
import { fetchProjects } from "../../lib/strapi";

const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);

const projects = await fetchProjects(lang);

function formatYear(date: string): string {
  return new Date(date).getFullYear().toString();
}

// Collect unique tags for filter pills
const allTags = Array.from(
  new Set(projects.flatMap((p: any) => p.tags ?? []))
).slice(0, 6);
---

<MainLayout
  lang={lang}
  title={t("project.meta.title")}
  description={t("project.meta.description")}
>
  <!-- HERO -->
  <section class="proj-hero">
    <div class="proj-watermark" aria-hidden="true">
      {lang === "es" ? "obras" : "works"}
    </div>
    <div class="proj-hero-inner">
      <div class="eyebrow" style="margin-bottom: 24px;">
        {lang === "es" ? `Proyectos · ${projects.length} piezas` : `Projects · ${projects.length} pieces`}
      </div>
      <h1 class="proj-hero-title">
        {lang === "es"
          ? <>{`Trabajo `}<em class="proj-hero-em">{`selecto`}</em>{` y contribuciones`}</>
          : <>{`Selected `}<em class="proj-hero-em">{`work`}</em>{` and contributions`}</>}
      </h1>
      <p class="proj-hero-subtitle">
        {lang === "es"
          ? "Plataformas, sistemas de diseño y herramientas internas construidas en los últimos nueve años. Algunos en producción, otros open source, todos documentados."
          : "Platforms, design systems and internal tooling built over the last nine years. Some in production, some open source, all documented."}
      </p>
    </div>
  </section>

  <!-- FILTER PILLS -->
  <section class="proj-filters">
    <div class="proj-filters-inner">
      <div class="proj-filter-pills" id="proj-tags">
        <button class="proj-pill active" data-tag="all">
          {lang === "es" ? "Todos" : "All"}
        </button>
        {allTags.map((tag: string) => (
          <button class="proj-pill" data-tag={tag}>{tag}</button>
        ))}
      </div>
    </div>
  </section>

  <!-- 2-COL GRID -->
  <section class="proj-grid-section">
    <div class="proj-grid-inner">
      {projects.length === 0 && (
        <p class="proj-empty">
          {lang === "es" ? "Próximamente..." : "Coming soon..."}
        </p>
      )}

      {projects.length > 0 && (
        <div class="proj-grid" id="proj-grid">
          {projects.map((project: any, i: number) => (
            <a
              href={`/${lang}/projects/${project.slug}`}
              class="proj-card"
              data-tags={JSON.stringify(project.tags ?? [])}
            >
              <div class="proj-card-top">
                <span class="proj-card-counter">
                  {String(i + 1).padStart(2, "0")} / {String(projects.length).padStart(2, "0")}
                </span>
                <span class="proj-card-year">
                  {project.publishDate ? formatYear(project.publishDate) : "—"}
                </span>
              </div>

              {project.tags?.[0] && (
                <div class="proj-card-kind">{project.tags[0]}</div>
              )}

              <h3 class="proj-card-title">{project.title}</h3>
              <p class="proj-card-desc">{project.description}</p>

              <div class="proj-card-footer">
                <div class="proj-card-tech">
                  {project.technologies?.slice(0, 3).map((tech: string) => (
                    <span class="proj-tech-badge">{tech}</span>
                  ))}
                </div>
                <span class="proj-card-cta">
                  {lang === "es" ? "Ver caso →" : "View case →"}
                </span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="proj-cta-section">
    <div class="proj-cta-inner">
      <div class="eyebrow" style="margin-bottom: 24px; justify-content: center;">
        {lang === "es" ? "¿Falta algo?" : "Want more?"}
      </div>
      <h2 class="proj-cta-title">
        {lang === "es"
          ? <>{`Más en `}<em class="proj-cta-em">{`GitHub`}</em></>
          : <>{`More on `}<em class="proj-cta-em">{`GitHub`}</em></>}
      </h2>
      <p class="proj-cta-desc">
        {lang === "es"
          ? "Contribuciones open source, experimentos y dotfiles. Si te interesa algo específico, escríbeme."
          : "Open source contributions, experiments and dotfiles. If you're interested in something specific, reach out."}
      </p>
      <div class="proj-cta-btns">
        <a href={NETWORK.GITHUB} target="_blank" rel="noopener" class="proj-btn-primary">
          {lang === "es" ? "Ver en GitHub ↗" : "View on GitHub ↗"}
        </a>
        <a href={`/${lang}/contact`} class="proj-btn-ghost">
          {lang === "es" ? "Contactar" : "Contact"}
        </a>
      </div>
    </div>
  </section>
</MainLayout>

<script>
  const tagsEl = document.getElementById("proj-tags");
  const grid = document.getElementById("proj-grid");

  if (tagsEl && grid) {
    let activeTag = "all";

    tagsEl.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".proj-pill");
      if (!btn) return;
      activeTag = btn.dataset.tag ?? "all";
      tagsEl.querySelectorAll(".proj-pill").forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");

      grid.querySelectorAll<HTMLElement>(".proj-card").forEach((card) => {
        const tags: string[] = JSON.parse(card.dataset.tags ?? "[]");
        const match = activeTag === "all" || tags.includes(activeTag);
        card.style.display = match ? "" : "none";
      });
    });
  }
</script>

<style>
  /* HERO */
  .proj-hero {
    position: relative;
    overflow: hidden;
    padding: 100px 48px 60px;
    border-bottom: 1px solid var(--color-base-300);
  }

  .proj-watermark {
    position: absolute;
    right: -40px;
    top: 30px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(180px, 26vw, 430px);
    font-weight: 300;
    color: var(--color-base-200);
    line-height: 0.85;
    pointer-events: none;
    user-select: none;
  }

  .proj-hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .proj-hero-title {
    font-family: var(--font-display);
    font-size: clamp(48px, 7vw, 96px);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 0.98;
    margin: 0 0 24px;
    color: var(--color-base-content);
    max-width: 900px;
    text-wrap: pretty;
  }

  .proj-hero-em {
    font-style: italic;
    color: var(--color-accent);
    font-weight: 300;
  }

  .proj-hero-subtitle {
    font-size: 18px;
    line-height: 1.55;
    color: var(--color-base-content);
    opacity: 0.6;
    max-width: 640px;
    margin: 0;
  }

  /* FILTERS */
  .proj-filters {
    padding: 28px 48px;
    border-bottom: 1px solid var(--color-base-300);
  }

  .proj-filters-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .proj-filter-pills {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }

  .proj-pill {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    padding: 5px 14px;
    border-radius: 999px;
    background: transparent;
    color: var(--color-base-content);
    opacity: 0.55;
    border: 1px solid var(--color-base-300);
    cursor: pointer;
    transition: all 0.15s;
  }

  .proj-pill:hover { opacity: 0.85; }

  .proj-pill.active {
    background: var(--color-accent);
    color: var(--color-base-100);
    border-color: var(--color-accent);
    opacity: 1;
  }

  /* GRID */
  .proj-grid-section {
    padding: 60px 48px;
  }

  .proj-grid-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .proj-empty {
    font-family: var(--font-mono);
    font-size: 13px;
    opacity: 0.4;
    padding: 40px 0;
  }

  .proj-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
    background: var(--color-base-300);
  }

  .proj-card {
    background: var(--color-base-100);
    padding: 48px 40px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-height: 340px;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s;
    cursor: pointer;
  }

  .proj-card:hover {
    background: var(--color-base-200);
  }

  .proj-card-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .proj-card-counter {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-accent);
    letter-spacing: 0.1em;
  }

  .proj-card-year {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-base-content);
    opacity: 0.35;
    letter-spacing: 0.08em;
  }

  .proj-card-kind {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-base-content);
    opacity: 0.4;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .proj-card-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 500;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--color-base-content);
    line-height: 1.05;
  }

  .proj-card-desc {
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-base-content);
    opacity: 0.6;
    margin: 0;
    flex: 1;
  }

  .proj-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding-top: 16px;
    border-top: 1px solid var(--color-base-300);
    margin-top: auto;
  }

  .proj-card-tech {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .proj-tech-badge {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 3px 8px;
    border: 1px solid var(--color-base-300);
    border-radius: 999px;
    color: var(--color-base-content);
    opacity: 0.55;
  }

  .proj-card-cta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-accent);
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  /* CTA SECTION */
  .proj-cta-section {
    padding: 100px 48px;
    border-top: 1px solid var(--color-base-300);
  }

  .proj-cta-inner {
    max-width: 820px;
    margin: 0 auto;
    text-align: center;
  }

  .proj-cta-title {
    font-family: var(--font-display);
    font-size: clamp(34px, 5vw, 58px);
    font-weight: 400;
    letter-spacing: -0.02em;
    margin: 0 0 20px;
    color: var(--color-base-content);
    text-wrap: balance;
  }

  .proj-cta-em {
    font-style: italic;
    color: var(--color-accent);
    font-weight: 300;
  }

  .proj-cta-desc {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-base-content);
    opacity: 0.6;
    max-width: 520px;
    margin: 0 auto 32px;
  }

  .proj-cta-btns {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .proj-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    border-radius: 4px;
    font-weight: 500;
    font-size: 14px;
    background: var(--color-accent);
    color: var(--color-base-100);
    border: 1px solid transparent;
    text-decoration: none;
    font-family: var(--font-body);
    transition: all 0.2s;
  }

  .proj-btn-primary:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
  }

  .proj-btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    border-radius: 4px;
    font-weight: 500;
    font-size: 14px;
    background: transparent;
    color: var(--color-base-content);
    border: 1px solid var(--color-base-300);
    text-decoration: none;
    font-family: var(--font-body);
    transition: all 0.2s;
  }

  .proj-btn-ghost:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .proj-hero, .proj-filters, .proj-grid-section, .proj-cta-section {
      padding-left: 24px;
      padding-right: 24px;
    }

    .proj-grid {
      grid-template-columns: 1fr;
    }

    .proj-watermark {
      font-size: clamp(100px, 30vw, 200px);
    }
  }
</style>
