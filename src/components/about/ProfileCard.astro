---
import { NETWORK } from "../../constants/network";

interface Props {
  role: string;
  tagline: string;
  description: string;
  lang?: string;
}

const { role, tagline, description, lang = "es" } = Astro.props;
---

<section class="profile-hero">
  <div class="profile-inner">
    <!-- Left: copy -->
    <div class="profile-copy">
      <div class="eyebrow" style="margin-bottom: 24px;">
        {lang === "es" ? "Sobre mí" : "About me"}
      </div>

      <h1 class="profile-name">
        Ariel Itzli
        <em class="name-accent">Molina</em>
        Sánchez
      </h1>

      <p class="profile-tagline">{tagline}</p>
      <p class="profile-desc">{description}</p>

      <div class="profile-ctas">
        <a href={NETWORK.RESUME} target="_blank" rel="noopener" class="profile-btn-primary">
          {lang === "es" ? "Descargar CV" : "Download CV"}
          <span>↓</span>
        </a>
        <a href={NETWORK.LINKEDIN} target="_blank" rel="noopener" class="profile-btn-ghost">
          LinkedIn
        </a>
        <a href={NETWORK.GITHUB} target="_blank" rel="noopener" class="profile-btn-ghost">
          GitHub
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  .profile-hero {
    padding: 100px 48px 60px;
    border-bottom: 1px solid var(--color-base-300);
  }

  .profile-inner {
    max-width: 860px;
    margin: 0 auto;
  }

  .profile-copy {
    display: flex;
    flex-direction: column;
  }

  .profile-name {
    font-family: var(--font-display);
    font-size: clamp(44px, 6vw, 80px);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1;
    margin: 0 0 24px;
    color: var(--color-base-content);
    text-wrap: pretty;
  }

  .name-accent {
    font-style: italic;
    font-weight: 300;
    color: var(--color-accent);
  }

  .profile-tagline {
    font-family: var(--font-display);
    font-size: 20px;
    font-style: italic;
    line-height: 1.5;
    color: var(--color-base-content);
    opacity: 0.8;
    max-width: 560px;
    margin: 0 0 20px;
    font-weight: 400;
    text-wrap: pretty;
  }

  .profile-desc {
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-base-content);
    opacity: 0.65;
    max-width: 560px;
    margin: 0 0 32px;
  }

  .profile-ctas {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .profile-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    border-radius: 4px;
    font-weight: 500;
    font-size: 14px;
    background: var(--color-accent);
    color: var(--color-base-100);
    border: 1px solid transparent;
    text-decoration: none;
    font-family: var(--font-body);
    transition: all 0.2s;
  }

  .profile-btn-primary:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
  }

  .profile-btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    border-radius: 4px;
    font-weight: 500;
    font-size: 14px;
    background: transparent;
    color: var(--color-base-content);
    border: 1px solid var(--color-base-300);
    text-decoration: none;
    font-family: var(--font-body);
    transition: all 0.2s;
  }

  .profile-btn-ghost:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  @media (max-width: 900px) {
    .profile-hero { padding: 60px 24px 40px; }
  }
</style>
