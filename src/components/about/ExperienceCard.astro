---
import experiencesEn from "../../i18n/languages/experiences/en.json";
import experiencesEs from "../../i18n/languages/experiences/es.json";

interface Experience {
  role: string;
  company: string;
  period: string;
  description: string;
  technologies: string[];
  achievements: string[];
}

interface Props {
  title: string;
  lang?: "en" | "es";
}

const { title, lang = "en" } = Astro.props;

const experiences = lang === "en" ? experiencesEn.experiences : experiencesEs.experiences;
---

<section class="experience-section">
  <div class="experience-inner">
    <!-- Section header -->
    <div class="experience-header">
      <div class="eyebrow" style="margin-bottom: 12px;">
        {lang === "es" ? "02 · Experiencia" : "02 · Experience"}
      </div>
      <h2 class="experience-title">
        {lang === "es"
          ? <>{`Dónde he `}<em>{`construido`}</em></>
          : <>{`Where I've `}<em>{`built`}</em></>}
      </h2>
    </div>

    <!-- Timeline -->
    <div class="experience-list">
      {experiences.map((exp) => (
        <div class="exp-row group">
          <div class="exp-period">{exp.period}</div>
          <div class="exp-content">
            <h3 class="exp-role">{exp.role}</h3>
            <div class="exp-company">@ {exp.company}</div>
            <p class="exp-desc">{exp.description}</p>
            <ul class="exp-achievements">
              {exp.achievements.map((ach) => (
                <li class="exp-achievement">{ach}</li>
              ))}
            </ul>
            <div class="exp-tech">
              {exp.technologies.map((tech) => (
                <span class="exp-tech-badge">{tech}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .experience-section {
    padding: 100px 48px;
    background: var(--color-base-200);
    border-top: 1px solid var(--color-base-300);
    border-bottom: 1px solid var(--color-base-300);
  }

  .experience-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .experience-header {
    margin-bottom: 60px;
  }

  .experience-title {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 52px);
    font-weight: 400;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--color-base-content);
  }

  .experience-title em {
    font-style: italic;
    font-weight: 300;
  }

  /* Timeline rows */
  .experience-list {
    display: flex;
    flex-direction: column;
  }

  .exp-row {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 48px;
    padding: 40px 0;
    border-top: 1px solid var(--color-base-300);
    position: relative;
    transition: opacity 0.3s ease;
  }

  .experience-list:has(.exp-row:hover) .exp-row:not(:hover) {
    opacity: 0.45;
  }

  .exp-period {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-base-content);
    opacity: 0.45;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding-top: 4px;
  }

  .exp-content {}

  .exp-role {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: 0 0 6px;
    color: var(--color-base-content);
  }

  .exp-company {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-accent);
    letter-spacing: 0.08em;
    margin-bottom: 16px;
  }

  .exp-desc {
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-base-content);
    opacity: 0.65;
    margin: 0 0 18px;
    max-width: 640px;
  }

  .exp-achievements {
    list-style: none;
    padding: 0;
    margin: 0 0 18px;
    display: grid;
    gap: 8px;
  }

  .exp-achievement {
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-base-content);
    opacity: 0.75;
    padding-left: 20px;
    position: relative;
  }

  .exp-achievement::before {
    content: "▹";
    position: absolute;
    left: 0;
    top: 1px;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .exp-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .exp-tech-badge {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 3px 10px;
    border: 1px solid var(--color-base-300);
    border-radius: 999px;
    color: var(--color-base-content);
    opacity: 0.6;
  }

  @media (max-width: 900px) {
    .experience-section {
      padding: 60px 24px;
    }

    .exp-row {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
</style>
