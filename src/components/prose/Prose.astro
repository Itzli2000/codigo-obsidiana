---
---
<div class="editorial-prose">
  <slot />
</div>

<style is:global>
  .editorial-prose {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.78;
    color: var(--color-base-content);
  }

  .editorial-prose h1,
  .editorial-prose h2,
  .editorial-prose h3,
  .editorial-prose h4,
  .editorial-prose h5 {
    font-family: var(--font-display);
    font-weight: 500;
    letter-spacing: -0.02em;
    margin: 2.2em 0 0.55em;
    color: var(--color-base-content);
    line-height: 1.1;
  }
  .editorial-prose h1 { font-size: 40px; }
  .editorial-prose h2 { font-size: 30px; }
  .editorial-prose h3 { font-size: 23px; }
  .editorial-prose h4 { font-size: 18px; }

  .editorial-prose p { margin: 0 0 1.5em; }

  .editorial-prose a {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: opacity 0.15s;
  }
  .editorial-prose a:hover { opacity: 0.75; }

  .editorial-prose strong { font-weight: 600; }
  .editorial-prose em { font-style: italic; }

  .editorial-prose blockquote {
    border-left: 2px solid var(--color-accent);
    padding: 4px 0 4px 20px;
    margin: 1.8em 0;
    font-style: italic;
    color: var(--color-base-content);
    opacity: 0.72;
  }

  .editorial-prose code {
    font-family: var(--font-mono);
    font-size: 0.87em;
    background: var(--color-base-200);
    border: 1px solid var(--color-base-300);
    padding: 2px 6px;
    border-radius: 3px;
  }

  .editorial-prose pre {
    background: var(--color-base-200);
    border: 1px solid var(--color-base-300);
    padding: 20px 24px;
    overflow-x: auto;
    border-radius: 4px;
    margin: 1.8em 0;
  }
  .editorial-prose pre code {
    background: transparent;
    border: none;
    padding: 0;
    font-size: 14px;
    line-height: 1.65;
  }

  .editorial-prose ul,
  .editorial-prose ol {
    padding-left: 24px;
    margin: 0 0 1.5em;
  }
  .editorial-prose li { margin-bottom: 0.45em; }
  .editorial-prose li::marker { color: var(--color-accent); }

  .editorial-prose hr {
    border: none;
    border-top: 1px solid var(--color-base-300);
    margin: 3em 0;
  }

  .editorial-prose img {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 2em auto;
  }

  .editorial-prose table {
    width: 100%;
    border-collapse: collapse;
    font-size: 15px;
    margin: 2em 0;
  }
  .editorial-prose th {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-bottom: 2px solid var(--color-base-300);
    padding: 8px 12px;
    text-align: left;
    opacity: 0.55;
  }
  .editorial-prose td {
    border-bottom: 1px solid var(--color-base-300);
    padding: 10px 12px;
    vertical-align: top;
  }
  .editorial-prose tr:last-child td { border-bottom: none; }
</style>
