---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { fetchProjects } from "../../lib/strapi";
import type { Lang } from "../../types/language";

const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);

const allProjects = await fetchProjects(lang, { showInAboutOnly: true });
const featuredProjects = allProjects.slice(0, 4);

function formatYear(date: string): string {
  return new Date(date).getFullYear().toString();
}
---

<section class="projects-section">
  <div class="projects-inner">
    <!-- Header -->
    <div class="projects-header">
      <div class="eyebrow" style="margin-bottom: 12px;">
        {lang === 'es' ? 'Trabajo selecto' : 'Selected work'}
      </div>
      <h2 class="projects-title">
        {lang === 'es'
          ? <>{`Proyectos `}<em>{`destacados`}</em></>
          : <>{`Featured `}<em>{`projects`}</em></>}
      </h2>
    </div>

    <!-- Grid -->
    {featuredProjects.length > 0 ? (
      <div class="projects-grid">
        {featuredProjects.map((project, i) => (
          <a href={`/${lang}/projects/${project.slug}`} class="project-card">
            <div class="project-card-top">
              <span class="project-counter">
                {String(i + 1).padStart(2, '0')} / {String(featuredProjects.length).padStart(2, '0')}
              </span>
              <span class="project-year">
                {project.publishDate ? formatYear(project.publishDate) : '—'}
              </span>
            </div>
            {project.technologies && project.technologies[0] && (
              <div class="project-kind">{project.technologies[0]}</div>
            )}
            <h3 class="project-title">{project.title}</h3>
            <p class="project-desc">{project.description}</p>
            <div class="project-footer">
              <div class="project-tech">
                {project.technologies.slice(0, 3).map((tech: string) => (
                  <span class="tech-badge">{tech}</span>
                ))}
              </div>
              <span class="project-cta">
                {lang === 'es' ? 'Ver caso →' : 'View case →'}
              </span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p style="opacity: 0.4; font-family: var(--font-mono); font-size: 13px; padding: 40px 0;">
        {lang === 'es' ? 'Próximamente...' : 'Coming soon...'}
      </p>
    )}

    <!-- View all -->
    <div class="projects-cta-row">
      <a href={`/${lang}/projects`} class="btn-editorial-ghost-sm">
        {lang === 'es' ? 'Ver todos los proyectos →' : 'View all projects →'}
      </a>
    </div>
  </div>
</section>

<style>
  .projects-section {
    padding: 100px 48px;
    background: var(--color-base-200);
  }

  .projects-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .projects-header {
    margin-bottom: 60px;
  }

  .projects-title {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 54px);
    font-weight: 400;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--color-base-content);
  }

  .projects-title em {
    font-style: italic;
    font-weight: 300;
  }

  /* 2-col grid with 2px gap (border trick) */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
    background: var(--color-base-300);
    margin-bottom: 40px;
  }

  .project-card {
    background: var(--color-base-200);
    padding: 40px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-height: 300px;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s;
    cursor: pointer;
  }

  .project-card:hover {
    background: var(--color-base-100);
  }

  .project-card-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .project-counter {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-accent);
    letter-spacing: 0.1em;
  }

  .project-year {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-base-content);
    opacity: 0.35;
    letter-spacing: 0.08em;
  }

  .project-kind {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-base-content);
    opacity: 0.4;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .project-title {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 34px);
    font-weight: 500;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--color-base-content);
    line-height: 1.05;
  }

  .project-desc {
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-base-content);
    opacity: 0.65;
    margin: 0;
    flex: 1;
  }

  .project-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding-top: 16px;
    border-top: 1px solid var(--color-base-300);
    margin-top: auto;
  }

  .project-tech {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .tech-badge {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 3px 8px;
    border: 1px solid var(--color-base-300);
    border-radius: 999px;
    color: var(--color-base-content);
    opacity: 0.6;
  }

  .project-cta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-base-content);
    opacity: 0.5;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .projects-cta-row {
    display: flex;
    justify-content: center;
  }

  .btn-editorial-ghost-sm {
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 10px 20px;
    border: 1px solid var(--color-base-300);
    border-radius: 4px;
    color: var(--color-base-content);
    opacity: 0.6;
    text-decoration: none;
    transition: all 0.15s;
    letter-spacing: 0.06em;
  }

  .btn-editorial-ghost-sm:hover {
    opacity: 1;
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  @media (max-width: 700px) {
    .projects-section {
      padding: 60px 24px;
    }

    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
