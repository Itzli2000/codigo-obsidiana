---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { CDN, TYPE } from "../../constants/cdn";
import { fetchBlogPosts } from "../../lib/strapi";
import type { Lang } from "../../types/language";

const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);

const allPosts = await fetchBlogPosts(lang, { excludeDrafts: true });
const featuredPosts = allPosts.slice(0, 3);

function formatDate(date: string): string {
  const d = new Date(date);
  const utc = new Date(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate());
  const y = utc.getFullYear();
  const m = String(utc.getMonth() + 1).padStart(2, '0');
  const day = String(utc.getDate()).padStart(2, '0');
  return `${y} · ${m} · ${day}`;
}
---

<section class="writing-section">
  <div class="writing-inner">
    <!-- Header -->
    <div class="writing-header">
      <div>
        <div class="eyebrow" style="margin-bottom: 12px;">{lang === 'es' ? 'Escribiendo' : 'Writing'}</div>
        <h2 class="writing-title">
          {lang === 'es'
            ? <>{`Últimas `}<em>{`notas`}</em></>
            : <>{`Latest `}<em>{`notes`}</em></>}
        </h2>
      </div>
      <a href={`/${lang}/blog`} class="writing-view-all">
        {lang === 'es' ? 'Ver todas →' : 'View all →'}
      </a>
    </div>

    <!-- Post rows -->
    <div class="writing-list">
      {featuredPosts.length === 0 && (
        <p style="padding: 40px 0; opacity: 0.4; font-family: var(--font-mono); font-size: 13px;">
          {lang === 'es' ? 'Próximamente...' : 'Coming soon...'}
        </p>
      )}
      {featuredPosts.map((post, i) => (
        <a
          href={`/${lang}/blog/${post.slug}`}
          class="post-row writing-row"
          data-post-row
        >
          <span class="row-num">{String(i + 1).padStart(2, '0')}</span>
          <span class="row-date">{post.publishDate ? formatDate(post.publishDate) : '—'}</span>
          <div class="row-title-wrap">
            {post.tags && post.tags[0] && (
              <div class="row-tag">{post.tags[0]}</div>
            )}
            <div class="row-title">{post.title}</div>
          </div>
          <p class="row-desc">{post.description}</p>
          <span class="row-read">
            {post.readingTime ? `${post.readingTime} min ↗` : '↗'}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .writing-section {
    padding: 100px 48px;
  }

  .writing-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .writing-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 48px;
  }

  .writing-title {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 54px);
    font-weight: 400;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--color-base-content);
  }

  .writing-title em {
    font-style: italic;
    font-weight: 300;
  }

  .writing-view-all {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-base-content);
    opacity: 0.5;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: opacity 0.15s, color 0.15s;
    white-space: nowrap;
    padding-bottom: 4px;
  }

  .writing-view-all:hover {
    opacity: 1;
    color: var(--color-accent);
  }

  .writing-list {
    border-top: 1px solid var(--color-base-300);
  }

  .writing-row {
    display: grid;
    grid-template-columns: 60px 120px 1fr 1fr auto;
    gap: 32px;
    align-items: baseline;
    padding: 28px 0;
    border-bottom: 1px solid var(--color-base-300);
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    border-radius: 0;
  }

  .writing-row:hover {
    background: var(--color-base-200);
    padding-left: 16px;
    padding-right: 16px;
    margin-left: -16px;
    margin-right: -16px;
  }

  .row-num {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-base-content);
    opacity: 0.35;
  }

  .row-date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-base-content);
    opacity: 0.4;
    letter-spacing: 0.08em;
  }

  .row-title-wrap {}

  .row-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-accent);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .row-title {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-base-content);
    line-height: 1.2;
    text-wrap: balance;
  }

  .row-desc {
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-base-content);
    opacity: 0.6;
    margin: 0;
    max-width: 340px;
  }

  .row-read {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-base-content);
    opacity: 0.4;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  @media (max-width: 900px) {
    .writing-section {
      padding: 60px 24px;
    }

    .writing-row {
      grid-template-columns: 40px 1fr auto;
      gap: 16px;
    }

    .row-date, .row-desc {
      display: none;
    }

    .writing-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }
  }
</style>
