---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import type { Lang } from "../../types/language";

const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);

const stats = lang === 'es'
  ? [
      ['9+', 'años enviando', 'software'],
      ['$100M', 'transacciones', 'mensuales'],
      ['70%', 'reducción de', 'time-to-market'],
    ]
  : [
      ['9+', 'years shipping', 'software'],
      ['$100M', 'monthly', 'transactions'],
      ['70%', 'reduction in', 'time-to-market'],
    ];
---

<section class="hero-editorial">
  <!-- Background watermark -->
  <div class="hero-watermark" aria-hidden="true">obsidiana</div>

  <div class="hero-inner">
    <!-- Left: copy -->
    <div class="hero-copy">
      <div class="eyebrow" style="margin-bottom: 24px;">
        {lang === 'es' ? 'Staff Frontend Engineer · CDMX' : 'Staff Frontend Engineer · CDMX'}
      </div>

      <h1 class="hero-heading">
        {lang === 'es'
          ? <>Construyo <em class="accent-em">plataformas</em><br />que escalan con la<br />precisión del <em>código</em>.</>
          : <>I build <em class="accent-em">platforms</em><br />that scale with the<br />precision of <em>code</em>.</>}
      </h1>

      <p class="hero-subtitle">
        {lang === 'es'
          ? <>Arquitecto frontend con 9+ años construyendo infraestructuras modulares, sistemas de diseño y herramientas internas. Actualmente en EFEX, liderando la plataforma de micro frontends que procesa <span class="hero-highlight">$100M USD mensuales</span>.</>
          : <>Frontend architect with 9+ years building modular infrastructure, design systems and internal tooling. Currently at EFEX, leading the micro frontends platform processing <span class="hero-highlight">$100M USD monthly</span>.</>}
      </p>

      <div class="hero-ctas">
        <a href={`/${lang}/about`} class="btn-editorial btn-editorial-primary">
          {lang === 'es' ? 'Conóceme' : 'About me'} <span>→</span>
        </a>
        <a href={`/${lang}/blog`} class="btn-editorial btn-editorial-ghost">
          {lang === 'es' ? 'Leer el blog' : 'Read the blog'}
        </a>
      </div>

      <!-- Stats row -->
      <div class="hero-stats">
        {stats.map(([n, a, b]) => (
          <div class="stat-item">
            <div class="stat-number">{n}</div>
            <div class="stat-label">{a}<br />{b}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Right: Portrait -->
    <div class="hero-avatar-wrap">
      <div class="avatar-card">
        <svg class="avatar-placeholder" viewBox="0 0 320 368" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
          <defs>
            <linearGradient id="avatar-g" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="var(--color-base-200)" />
              <stop offset="1" stop-color="var(--color-base-100)" />
            </linearGradient>
            <pattern id="avatar-stripe" width="3" height="3" patternUnits="userSpaceOnUse">
              <line x1="0" y1="0" x2="0" y2="3" stroke="var(--color-base-300)" stroke-width="0.6" />
            </pattern>
          </defs>
          <rect width="320" height="368" fill="url(#avatar-g)" />
          <rect width="320" height="368" fill="url(#avatar-stripe)" opacity="0.5" />
          <g opacity="0.7">
            <ellipse cx="160" cy="155" rx="62" ry="78" fill="var(--color-base-300)" />
            <path d="M 70 368 Q 70 250 160 250 Q 250 250 250 368 Z" fill="var(--color-base-300)" />
            <circle cx="160" cy="140" r="55" fill="var(--color-base-content)" opacity="0.15" />
          </g>
        </svg>
        <div class="avatar-caption">
          <div class="avatar-caption-label">Retrato — 2026</div>
          <div class="avatar-caption-name">Ariel Molina</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-editorial {
    position: relative;
    overflow: hidden;
    padding: 120px 48px 100px;
    border-bottom: 1px solid var(--color-base-300);
  }

  .hero-watermark {
    position: absolute;
    right: -40px;
    top: 40px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(200px, 28vw, 480px);
    font-weight: 300;
    color: var(--color-base-200);
    line-height: 0.85;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
  }

  .hero-heading {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(48px, 6.5vw, 92px);
    line-height: 0.98;
    letter-spacing: -0.03em;
    margin: 0 0 28px;
    color: var(--color-base-content);
    text-wrap: pretty;
  }

  .accent-em {
    font-style: italic;
    color: var(--color-accent);
    font-weight: 300;
  }

  .hero-heading em {
    font-style: italic;
    font-weight: 300;
  }

  .hero-subtitle {
    font-size: 18px;
    line-height: 1.55;
    color: var(--color-base-content);
    opacity: 0.7;
    max-width: 540px;
    margin: 0 0 36px;
    text-wrap: pretty;
  }

  .hero-highlight {
    color: var(--color-base-content);
    opacity: 1;
    border-bottom: 1px dashed var(--color-accent);
    padding-bottom: 1px;
  }

  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn-editorial {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 22px;
    border-radius: 4px;
    font-weight: 500;
    font-size: 14px;
    transition: all 0.2s;
    cursor: pointer;
    border: 1px solid transparent;
    text-decoration: none;
    font-family: var(--font-body);
  }

  .btn-editorial-primary {
    background: var(--color-accent);
    color: var(--color-base-100);
  }

  .btn-editorial-primary:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
  }

  .btn-editorial-ghost {
    background: transparent;
    color: var(--color-base-content);
    border-color: var(--color-base-300);
  }

  .btn-editorial-ghost:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .hero-stats {
    margin-top: 56px;
    padding-top: 28px;
    border-top: 1px solid var(--color-base-300);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 480px;
  }

  .stat-item {}

  .stat-number {
    font-family: var(--font-display);
    font-size: 34px;
    font-weight: 400;
    color: var(--color-base-content);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-base-content);
    opacity: 0.45;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 8px;
    line-height: 1.4;
  }

  /* Avatar */
  .hero-avatar-wrap {
    display: flex;
    justify-content: center;
    position: relative;
  }

  .fig-label {
    position: absolute;
    left: -10px;
    top: -10px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-base-content);
    opacity: 0.35;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    z-index: 2;
  }

  .avatar-card {
    position: relative;
    width: 100%;
    max-width: 340px;
    aspect-ratio: 320 / 368;
    background: var(--color-base-200);
    border: 1px solid var(--color-base-300);
    border-radius: 4px;
    overflow: hidden;
  }

  .avatar-placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .avatar-canvas-wrap {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .avatar-caption {
    position: absolute;
    inset: auto 0 0 0;
    padding: 20px;
    background: linear-gradient(180deg, transparent, oklch(10% 0.014 261 / 0.88));
    color: var(--color-base-content);
    z-index: 2;
  }

  [data-theme="obsidiana-light"] .avatar-caption {
    background: linear-gradient(180deg, transparent, oklch(98% 0.014 261 / 0.88));
  }

  .avatar-caption-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.55;
    margin-bottom: 4px;
  }

  .avatar-caption-name {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-base-content);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .hero-editorial {
      padding: 80px 24px 60px;
    }

    .hero-inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .hero-avatar-wrap {
      order: -1;
    }

    .avatar-card {
      max-width: 260px;
    }

    .hero-watermark {
      font-size: clamp(120px, 40vw, 260px);
      top: 20px;
      right: -20px;
    }
  }

  @media (max-width: 540px) {
    .hero-editorial {
      padding: 60px 20px 48px;
    }

    .hero-stats {
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
  }
</style>
