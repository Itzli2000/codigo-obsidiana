---
import ContactSection from "../../components/contact/ContactSection.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import MainLayout from "../../layouts/MainLayout.astro";
import type { Lang } from "../../types/language";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "es" } }];
}

const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);

const title = t("contact.title");
const description = t("contact.description");
---

<MainLayout lang={lang} title={title} description={description} type="website">
  <ContactSection />
</MainLayout>
