---
import ExperienceCard from "../../components/about/ExperienceCard.astro";
import ProfileCard from "../../components/about/ProfileCard.astro";
import SummaryCard from "../../components/about/SummaryCard.astro";
import StackGrid from "../../components/about/StackGrid.astro";
import EducationSection from "../../components/about/EducationSection.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import MainLayout from "../../layouts/MainLayout.astro";
import type { Lang } from "../../types/language";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "es" } }];
}

const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);

const title = "Ariel Itzli Molina Sanchez | Código Obsidiana";
const description =
  "Staff Frontend Engineer & Architect with 9+ years of experience building modular and scalable UI systems, specializing in micro frontends and design systems.";
---

<MainLayout title={title} lang={lang} description={description} type="profile">
  <ProfileCard
    role={t("about.role")}
    tagline={t("about.tagline")}
    description={t("about.description")}
    lang={lang}
  />
  <SummaryCard
    title={t("about.summary.title")}
    summary={t("about.summary.content")}
    lang={lang}
  />
  <ExperienceCard
    title={t("about.experience.title")}
    lang={lang}
  />
  <StackGrid lang={lang} />
  <EducationSection lang={lang} />
</MainLayout>
