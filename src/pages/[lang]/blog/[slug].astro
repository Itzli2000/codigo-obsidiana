---
import { Image } from "astro:assets";
import { marked } from "marked";
import Prose from "../../../components/prose/Prose.astro";
import MainLayout from "../../../layouts/MainLayout.astro";
import { getLangFromUrl } from "../../../i18n/utils";
import { CDN, TYPE } from "../../../constants/cdn";
import { fetchBlogPosts, fetchBlogPost } from "../../../lib/strapi";
import type { Lang } from "../../../types/language";

export async function getStaticPaths() {
  const [enPosts, esPosts] = await Promise.all([
    fetchBlogPosts("en"),
    fetchBlogPosts("es"),
  ]);

  const allSlugs = new Set([
    ...enPosts.map((p) => p.slug),
    ...esPosts.map((p) => p.slug),
  ]);

  return [...allSlugs].flatMap((slug) => [
    { params: { lang: "en", slug } },
    { params: { lang: "es", slug } },
  ]);
}

const lang = getLangFromUrl(Astro.url) as Lang;
const { slug } = Astro.params;

const post = await fetchBlogPost(lang, slug as string);

if (!post) {
  return Astro.redirect("/404");
}

const htmlBody = await marked(post.body);

function formatDate(date: string): string {
  const d = new Date(date);
  const utc = new Date(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate());
  return utc.toLocaleDateString(lang === "es" ? "es-MX" : "en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<MainLayout
  lang={lang}
  title={post.title}
  description={post.description}
  tags={post.tags}
  image={`${CDN.IMAGES}${TYPE.BLOG}${post.image}`}
  type="article"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": post.title,
    "description": post.description,
    "author": { "@type": "Person", "name": post.author },
    "datePublished": post.publishDate,
    "image": `${CDN.IMAGES}${TYPE.BLOG}${post.image}`,
    "inLanguage": lang,
    "publisher": {
      "@type": "Organization",
      "name": "Código Obsidiana",
      "url": "https://www.codigo-obsidiana.dev"
    }
  })} />

  <!-- ARTICLE HEADER -->
  <header class="art-header">
    <div class="art-header-inner">
      <a href={`/${lang}/blog`} class="art-back">
        ← {lang === "es" ? "Blog" : "Blog"}
      </a>

      <div class="art-meta">
        {post.tags?.[0] && (
          <span class="art-tag">{post.tags[0]}</span>
        )}
        {post.publishDate && (
          <span class="art-date">{formatDate(post.publishDate)}</span>
        )}
        {post.readingTime && (
          <span class="art-read">
            {post.readingTime} min {lang === "es" ? "de lectura" : "read"}
          </span>
        )}
      </div>

      <h1 class="art-title">{post.title}</h1>
      <p class="art-desc">{post.description}</p>

      <div class="art-byline">
        <span class="art-author">{post.author}</span>
        {post.updated && (
          <span class="art-updated">
            {lang === "es" ? "Actualizado" : "Updated"} {formatDate(post.updated)}
          </span>
        )}
      </div>
    </div>
  </header>

  <!-- COVER IMAGE -->
  {post.image && (
    <div class="art-cover">
      <div class="art-cover-inner">
        <Image
          src={`${CDN.IMAGES}${TYPE.BLOG}${post.image}`}
          alt={post.title}
          width={1200}
          height={630}
          class="art-cover-img"
          loading="eager"
        />
      </div>
    </div>
  )}

  <!-- BODY -->
  <div class="art-body">
    <div class="art-body-inner">
      <Prose>
        <Fragment set:html={htmlBody} />
      </Prose>
    </div>
  </div>

  <!-- FOOTER -->
  <footer class="art-footer">
    <div class="art-footer-inner">
      <a href={`/${lang}/blog`} class="art-footer-back">
        ← {lang === "es" ? "Volver al blog" : "Back to blog"}
      </a>
      {post.tags && post.tags.length > 0 && (
        <div class="art-footer-tags">
          {post.tags.map((tag) => (
            <span class="art-footer-tag">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </footer>
</MainLayout>

<style>
  .art-header {
    padding: 80px 48px 60px;
    border-bottom: 1px solid var(--color-base-300);
  }
  .art-header-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .art-back {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 40px;
    transition: opacity 0.15s;
  }
  .art-back:hover { opacity: 0.75; }

  .art-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 20px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--color-base-content);
    opacity: 0.5;
    flex-wrap: wrap;
  }
  .art-tag {
    color: var(--color-accent);
    opacity: 1;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .art-title {
    font-family: var(--font-display);
    font-size: clamp(34px, 5.5vw, 62px);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.02;
    margin: 0 0 20px;
    color: var(--color-base-content);
  }

  .art-desc {
    font-size: 18px;
    line-height: 1.62;
    color: var(--color-base-content);
    opacity: 0.65;
    margin: 0 0 28px;
    max-width: 640px;
  }

  .art-byline {
    display: flex;
    align-items: center;
    gap: 20px;
    font-family: var(--font-mono);
    font-size: 12px;
    flex-wrap: wrap;
  }
  .art-author { color: var(--color-base-content); opacity: 0.65; }
  .art-updated { color: var(--color-base-content); opacity: 0.35; font-size: 11px; }

  .art-cover {
    background: var(--color-base-200);
    border-bottom: 1px solid var(--color-base-300);
  }
  .art-cover-inner {
    max-width: 1000px;
    margin: 0 auto;
    padding: 40px 48px;
  }
  .art-cover-img { width: 100%; height: auto; display: block; }

  .art-body { padding: 80px 48px 100px; }
  .art-body-inner { max-width: 680px; margin: 0 auto; }

  .art-footer {
    padding: 32px 48px 80px;
    border-top: 1px solid var(--color-base-300);
  }
  .art-footer-inner {
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }
  .art-footer-back {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-accent);
    text-decoration: none;
    letter-spacing: 0.06em;
    transition: opacity 0.15s;
  }
  .art-footer-back:hover { opacity: 0.75; }

  .art-footer-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .art-footer-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 3px 10px;
    border: 1px solid var(--color-base-300);
    border-radius: 999px;
    color: var(--color-base-content);
    opacity: 0.5;
    letter-spacing: 0.08em;
  }

  @media (max-width: 760px) {
    .art-header,
    .art-body,
    .art-footer { padding-left: 24px; padding-right: 24px; }
    .art-cover-inner { padding: 24px; }
    .art-footer-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
