---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import MainLayout from "../../../layouts/MainLayout.astro";
import { Icon } from "astro-icon/components";
import { getLangFromUrl, useTranslations, getCollectionName } from "../../../i18n/utils";
import { CDN, TYPE } from "../../../constants/cdn";
import type { Lang } from "../../../types/language";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "es" } }];
}

const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);

const allPosts = await getCollection(getCollectionName("blog", lang), (entry) => !entry.data.draft);
const posts = allPosts.sort((a, b) =>
  new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
);

function formatDate(date: Date | string): string {
  const dateObj = new Date(date);
  const utcDate = new Date(
    dateObj.getUTCFullYear(),
    dateObj.getUTCMonth(),
    dateObj.getUTCDate()
  );

  return utcDate.toLocaleDateString(lang === "en" ? "en-US" : "es-ES", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

const title = t("blog.meta.title") !== "blog.meta.title"
  ? t("blog.meta.title")
  : "Blog | Ariel Itzli Molina Sanchez | Código Obsidiana";
const description = t("blog.meta.description") !== "blog.meta.description"
  ? t("blog.meta.description")
  : "Blog of Ariel Molina";
---

<MainLayout lang={lang} title={title} description={description}>
  <section class="hero-section mb-16">
    <h1 class="text-5xl font-bold font-serif mb-4 text-center md:text-left">
      {t("blog.title")}
    </h1>
    <p
      class="text-xl text-base-content/70 max-w-2xl mb-8 text-center md:text-left"
    >
      {t("blog.subtitle")}
    </p>
  </section>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
    {
      posts.map((post) => (
        <a href={`/${lang}/blog/${post.id}`} class="card-link group">
          <article class="card bg-base-100 shadow-sm hover:shadow-md transition-all duration-300 h-full overflow-hidden border border-base-300/50">
            {post.data.image && (
              <figure class="h-48 overflow-hidden">
                <Image
                  src={`${CDN.IMAGES}${TYPE.BLOG}${post.data.image}`}
                  alt={post.data.title}
                  width={400}
                  height={192}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </figure>
            )}

            <div class="card-body">
              <div class="flex items-center justify-between gap-2 text-sm text-base-content/60 mb-2">
                <span class="flex items-center gap-1">
                  <Icon name="mdi:calendar" class="w-4 h-4" />
                  {formatDate(post.data.publishDate)}
                </span>

                {post.data.readingTime && (
                  <span class="flex items-center gap-1">
                    <Icon name="mdi:clock" class="w-4 h-4" />
                    {post.data.readingTime} min
                  </span>
                )}
              </div>

              <h2 class="card-title text-xl font-bold group-hover:text-primary transition-colors duration-300">
                {post.data.title}
              </h2>

              <p class="text-base-content/80">{post.data.description}</p>

              <div class="card-actions justify-end mt-4">
                {post.data.tags &&
                  post.data.tags
                    .slice(0, 2)
                    .map((tag: string) => (
                      <div class="badge badge-outline">{tag}</div>
                    ))}
              </div>
            </div>
          </article>
        </a>
      ))
    }
  </div>

  {
    posts.length === 0 && (
      <div class="text-center py-16">
        <Icon
          name="mdi:empty"
          class="w-16 h-16 mx-auto mb-4 text-base-content/30"
        />
        <h2 class="text-2xl font-bold mb-2">
          {lang === "es" ? "Sin publicaciones aún" : "No posts yet"}
        </h2>
        <p class="text-base-content/70">
          {lang === "es" ? "Vuelve pronto para nuevo contenido." : "Check back soon for new content!"}
        </p>
      </div>
    )
  }
</MainLayout>
