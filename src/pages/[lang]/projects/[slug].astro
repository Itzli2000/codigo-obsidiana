---
import { marked } from "marked";
import MainLayout from "../../../layouts/MainLayout.astro";
import Prose from "../../../components/prose/Prose.astro";
import { CDN, TYPE } from "../../../constants/cdn";
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";
import { fetchProjects, fetchProject } from "../../../lib/strapi";
import type { Lang } from "../../../types/language";

export async function getStaticPaths() {
  const [enProjects, esProjects] = await Promise.all([
    fetchProjects("en"),
    fetchProjects("es"),
  ]);

  const allSlugs = new Set([
    ...enProjects.map((p) => p.slug),
    ...esProjects.map((p) => p.slug),
  ]);

  return [...allSlugs].flatMap((slug) => [
    { params: { lang: "en", slug } },
    { params: { lang: "es", slug } },
  ]);
}

const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);
const { slug } = Astro.params;

const project = await fetchProject(lang, slug as string);

if (!project) {
  return Astro.redirect("/404");
}

const htmlBody = await marked(project.body);

const backToProjects = lang === "es" ? "← Volver a Proyectos" : "← Back to Projects";
const backToAbout = lang === "es" ? "← Volver a Sobre mí" : "← Back to About";
---

<MainLayout
  lang={lang}
  title={project.title}
  description={project.description}
  tags={project.tags}
  image={`${CDN.IMAGES}${TYPE.PROJECT}${project.image}`}
>
  <a href={`/${lang}/projects`} class="btn btn-outline btn-info btn-sm mb-5" id="back-btn">
    {backToProjects}
  </a>

  <Prose>
    <Fragment set:html={htmlBody} />
  </Prose>
</MainLayout>

<script define:vars={{ lang, backToAbout }}>
  document.addEventListener('DOMContentLoaded', () => {
    const backBtn = document.getElementById('back-btn');

    if (backBtn) {
      const urlParams = new URLSearchParams(window.location.search);
      const fromParam = urlParams.get('from');

      if (fromParam === 'about') {
        backBtn.href = `/${lang}/about#projects`;
        backBtn.textContent = backToAbout;
      }
    }
  });
</script>
