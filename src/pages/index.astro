---
const siteUrl = Astro.site?.toString() || "";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ariel Molina - Software Engineer</title>
    <meta name="description" content="Software engineer specializing in frontend development, design systems, and interactive web experiences." />

    <meta http-equiv="refresh" content="0;url=/es" />
    <link rel="canonical" href={`${siteUrl}es`} />

    <link rel="alternate" hreflang="es" href={`${siteUrl}es`} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}en`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}es`} />
  </head>
  <body>
    <noscript>
      <p>Redirigiendo... / Redirecting...</p>
      <p><a href="/es">Ir al sitio en Español</a> | <a href="/en">Go to English site</a></p>
    </noscript>
    <script is:inline>
      (function() {
        var supportedLangs = ["en", "es"];
        var browserLang = (navigator.language || "").split("-")[0];
        var lang = supportedLangs.indexOf(browserLang) !== -1 ? browserLang : "es";
        window.location.replace("/" + lang);
      })();
    </script>
  </body>
</html>
